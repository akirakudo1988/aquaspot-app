generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  password  String
  createdAt DateTime   @default(now())
  spots     Spot[]
  reviews   Review[]
  favorites Favorite[]
}

model Spot {
  id             String     @id @default(cuid())
  name           String
  address        String
  prefecture     String
  city           String
  waterTypes     String
  operatingHours String?
  phone          String?
  instagram      String?
  notes          String?
  image          String?
  lat            Float?
  lng            Float?
  registeredById String
  registeredBy   User       @relation(fields: [registeredById], references: [id])
  createdAt      DateTime   @default(now())
  reviews        Review[]
  favorites      Favorite[]
}

model Review {
  id        String   @id @default(cuid())
  spotId    String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  spot      Spot     @relation(fields: [spotId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model Favorite {
  id     String @id @default(cuid())
  spotId String
  userId String
  spot   Spot   @relation(fields: [spotId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@unique([spotId, userId])
}
